{"nodes":[{"id":"zone-game-logic","type":"zone","position":{"x":63.601398601398614,"y":32.38927738927739},"data":{"participantId":"Game-Logic-Agent","label":"Game Logic Agent","description":"Core game loop and state management","color":"#3B82F6","status":"idle","systemPrompt":"You are a game systems engineer. Write clean, deterministic game loop logic, state machines, and physics/collision code. Prefer fixed timestep updates, keep side effects isolated, and ensure collision detection is frame-rate independent.","agentRuntime":"claude","providerModels":{"claude":"claude-sonnet-4-6","codex":"gpt-5.4-mini"},"openSections":[],"skills":[],"tools":{"webSearch":false,"codeExec":false,"fileRead":true,"fileWrite":true,"apiCalls":false,"shell":false},"behavior":{"mode":"sequential","retries":0,"onFailure":"stop","timeoutMs":30000},"permissions":{"readFiles":true,"writeFiles":true,"network":false,"shell":false},"envVars":[]},"width":520,"height":340,"zIndex":0,"measured":{"width":520,"height":340}},{"id":"comp-game-loop","type":"component","position":{"x":130,"y":173.6013986013986},"data":{"label":"Game Loop","description":"","specs":"Fixed-timestep requestAnimationFrame loop. Drives update() and render() each tick. Tracks delta time, pauses on visibility change.","category":"custom","iconName":"Clock","color":"#60A5FA","tag":"Core"},"zIndex":1,"measured":{"width":160,"height":59}},{"id":"comp-game-state","type":"component","position":{"x":382.4009324009324,"y":108.77622377622376},"data":{"label":"Game State","description":"","specs":"State machine: IDLE → RUNNING → GAME_OVER. Holds score, hi-score (localStorage), speed multiplier, and frame count. Emits state change events.","category":"custom","iconName":"Layers","color":"#93C5FD","tag":"State"},"zIndex":1,"measured":{"width":160,"height":59}},{"id":"comp-collision","type":"component","position":{"x":130,"y":300},"data":{"label":"Collision System","description":"","specs":"AABB collision between dino hitbox and obstacle hitb