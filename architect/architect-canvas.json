":"comp-obstacle-gen","type":"component","position":{"x":930,"y":170},"data":{"label":"Obstacle Generator","description":"","specs":"Spawns cacti (single/double/triple) and pterodactyls at randomized intervals. Gap between spawns derived from current speed and difficulty tier. Recycles from pool.","category":"custom","iconName":"Boxes","color":"#86EFAC","tag":"Spawner"},"zIndex":1,"measured":{"width":160,"height":59}},{"id":"comp-obstacle-pool","type":"component","position":{"x":830,"y":300},"data":{"label":"Obstacle Pool","description":"","specs":"Object pool of pre-allocated obstacle instances. Obstacles are reset and reused when they scroll off-screen. Avoids GC pressure during gameplay.","category":"custom","iconName":"Archive","color":"#A7F3D0","tag":"Perf"},"zIndex":1,"measured":{"width":160,"height":59}},{"id":"zone-presentation","type":"zone","position":{"x":60,"y":480},"data":{"participantId":"Presentation-Agent","label":"Presentation Agent","description":"Rendering, UI, input, and audio","color":"#A855F7","status":"idle","systemPrompt":"You are a frontend/game-UI engineer. Write performant Canvas 2D rendering code, handle keyboard/touch input, manage Web Audio API sound effects, and build score/HUD overlays. Keep rendering stateless — read from game state, never mutate it.","agentRuntime":"claude","providerModels":{"claude":"claude-sonnet-4-6","codex":"gpt-5.4-mini"},"openSections":[],"skills":[],"tools":{"webSearch":false,"codeExec":false,"fileRead":true,"fileWrite":true,"apiCalls":false,"shell":false},"behavior":{"mode":"sequential","retries":0,"onFailure":"stop","timeoutMs":30000},"permissions":{"readFiles":true,"writeFiles":true,"network":false,"shell":false},"envVars":[]},"width":1020,"height":300,"zIndex":0,"measured":{"width":1020,"height":300}},{"id":"comp-renderer","type":"component","position":{"x":160,"y":600},"data":{"label":"Canvas Renderer","description":"","specs":"Clears and redraws each frame via Canvas 2D. Renders ground, dino sprite, obs